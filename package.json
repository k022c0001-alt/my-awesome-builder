{
  "name": "my-awesome-builder",
  "version": "1.0.0",
  "private": true,
  "description": "Educational website builder with Tailwind CSS theming framework",
  "packageManager": "pnpm@8.15.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
