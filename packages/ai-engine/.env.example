# packages/ai-engine/.env.example
# Copy this file to .env and fill in the values.
# Never commit .env to source control.

# ── Server ────────────────────────────────────────────────────────────────────
# Port the Flask server listens on (default: 8765)
PORT=8765

# Set to "true" to enable Flask debug mode (auto-reload, detailed errors)
FLASK_DEBUG=false

# ── AI Provider Keys ──────────────────────────────────────────────────────────
# Gemini (Google AI)
GEMINI_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Anthropic / Claude
ANTHROPIC_API_KEY=

# ── Custom API Keys (forwarded from the front-end) ────────────────────────────
SQL_API_KEY=
CSS_API_KEY=

# ── Database (for SQL API) ────────────────────────────────────────────────────
# Default SQLite database path used when no db_path is provided in the request
DEFAULT_DB_PATH=./data/database.db

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (leave empty to allow all)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
